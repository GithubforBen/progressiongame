DB_NAME=financegame
DB_USER=financegame
# REQUIRED: set a strong password in production (no default provided)
DB_PASSWORD=

# REQUIRED: set a random secret of at least 32 chars (no default provided)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Allowed frontend origin(s) for CORS, comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:3000

# When true the backend honours X-Forwarded-For for client IP resolution
# (rate limiting, etc). Only enable this behind a trusted reverse proxy
# (e.g. Cloudflare Tunnel) that rewrites the header — otherwise clients
# can spoof it to bypass the auth rate limiter.
SECURITY_TRUST_FORWARDED_FOR=false

# Cloudflare Tunnel Setup:
# NUXT_PUBLIC_API_BASE = öffentliche Backend-URL, die der Browser aufruft
#   Lokal:            http://localhost:8080
#   Cloudflare Tunnel: https://api.deine-domain.com  (o.ä.)
NUXT_PUBLIC_API_BASE=http://localhost:8080

# NUXT_INTERNAL_API_BASE = interne Docker-URL für SSR-seitige API-Calls
#   Im Docker Compose-Netz immer http://backend:8080 (Standard, muss normalerweise nicht geändert werden)
# NUXT_INTERNAL_API_BASE=http://backend:8080
