DB_NAME=financegame
DB_USER=financegame
DB_PASSWORD=changeme
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Cloudflare Tunnel Setup:
# NUXT_PUBLIC_API_BASE = öffentliche Backend-URL, die der Browser aufruft
#   Lokal:            http://localhost:8080
#   Cloudflare Tunnel: https://api.deine-domain.com  (o.ä.)
NUXT_PUBLIC_API_BASE=http://localhost:8080

# NUXT_INTERNAL_API_BASE = interne Docker-URL für SSR-seitige API-Calls
#   Im Docker Compose-Netz immer http://backend:8080 (Standard, muss normalerweise nicht geändert werden)
# NUXT_INTERNAL_API_BASE=http://backend:8080
